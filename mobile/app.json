{
  "expo": {
    "name": "TuranEliteLimo",
    "slug": "turanelitelimo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "turanelitelimo",
    "userInterfaceStyle": "dark",
    "primaryColor": "#D4AF37",
    "description": "Premium chauffeur service across the Bay Area & Northern California. Live quotes, instant booking, real-time driver tracking.",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.turanelitelimo.app",
      "buildNumber": "1",
      "config": {
        "googleMapsApiKey": "AIzaSyCDlQDr5_EYzX_qQpFgFqUZe6yQa7p9T7A"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TuranEliteLimo uses your location to set your pickup point and let you watch your chauffeur approach in real time.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Drivers share their background location during active trips so passengers can see live ETA updates throughout the ride.",
        "NSCameraUsageDescription": "Drivers can upload a profile photo.",
        "NSPhotoLibraryUsageDescription": "Drivers can choose a profile photo from their library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:turanelitelimo.com",
        "applinks:www.turanelitelimo.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "package": "com.turanelitelimo.app",
      "versionCode": 2,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCDlQDr5_EYzX_qQpFgFqUZe6yQa7p9T7A"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "turanelitelimo.com"
            },
            {
              "scheme": "https",
              "host": "www.turanelitelimo.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Drivers share background location during active trips so passengers can see live ETA updates."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4AF37",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f7293fd3-fd4a-4b43-815c-07c410b601e9"
      }
    },
    "owner": "adamfayz98",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f7293fd3-fd4a-4b43-815c-07c410b601e9"
    }
  }
}
